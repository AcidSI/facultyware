      </div><!-- /main-content -->
    </main>

    <div id="toaster" class="toaster"></div>
    <script src="https://cdn.jsdelivr.net/npm/tsparticles@3.3.0/tsparticles.bundle.min.js"></script>

  <script>
    // Bungkus mesin animasinya ke dalam satu fungsi bernama "nyalakanPartikel"
    function nyalakanPartikel() {
      // Cek apakah kodingan library-nya ada dan elemen kanvasnya ada
      if (typeof tsParticles !== 'undefined' && document.getElementById("tsparticles")) {
        tsParticles.load({
          id: "tsparticles",
          options: {
            background: { color: { value: "transparent" } },
            particles: {
              number: { value: 60 }, 
              color: { value: "#94a3b8" }, 
              links: {
                enable: true,
                color: "#94a3b8",
                distance: 150,
                opacity: 0.3,
                width: 1,
              },
              move: { enable: true, speed: 1 },
              size: { value: { min: 1, max: 2 } },
            },
            interactivity: {
              events: { onHover: { enable: true, mode: "grab" } },
              modes: {
                grab: { distance: 140, links: { opacity: 0.8 } },
              },
            },
            detectRetina: true,
          },
        });
      }
    }

    // A. Pemicu 1: Jalankan saat halaman dibuka pertama kali atau di-refresh manual
    document.addEventListener("DOMContentLoaded", nyalakanPartikel);

    // B. Pemicu 2: Jalankan ulang setiap kali HTMX selesai pindah halaman (Tanpa Refresh)
    document.body.addEventListener("htmx:afterSwap", nyalakanPartikel);
  </script>

 <style>
  /* Mengatur animasi agar gerakannya mulus */
  #sidebar, #content {
    transition: all 0.3s ease-in-out !important;
  }
  
  /* Aturan saat sidebar ditutup */
  body.sidebar-closed #sidebar {
    transform: translateX(-100%) !important; /* Geser ke luar layar */
    opacity: 0 !important; /* Hilangkan seutuhnya */
    pointer-events: none !important; /* Matikan klik */
  }
  
  /* Aturan agar konten utama mengisi ruang kosong di kiri */
  body.sidebar-closed #content {
    margin-left: 0 !important;
  }
</style>

<script>
  (function() {
    // Ingat pilihan user (buka/tutup) di memori browser
    let isClosed = localStorage.getItem('sidebarClosed') === 'true';

    window.toggleSidebar = function() {
      isClosed = !isClosed;
      localStorage.setItem('sidebarClosed', isClosed);
      applySidebarState();
    };

    function applySidebarState() {
      if (isClosed) {
        // Pasang kelas ke body, biarkan CSS di atas yang bekerja
        document.body.classList.add('sidebar-closed');
      } else {
        // Cabut kelas dari body
        document.body.classList.remove('sidebar-closed');
      }
    }

    // Terapkan saat web baru dibuka
    document.addEventListener("DOMContentLoaded", applySidebarState);
    
    // Terapkan ulang saat HTMX ganti halaman (mencegah bug nyangkut)
    document.body.addEventListener("htmx:afterSwap", applySidebarState);
    
    // Inisialisasi awal saat skrip dibaca
    applySidebarState();
  })();
</script>
