<%- include('../partials/_head.ejs') %>

<div class="p-4 md:p-6 xl:p-12">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6 flex items-center gap-2">
      <a href="/requests" class="btn-sm-ghost" hx-boost="true">← Kembali</a>
    </div>

    <div class="card p-6 md:p-8">
      <header class="mb-6">
        <h2 class="text-xl font-bold">Formulir Permohonan Surat</h2>
        <p class="text-muted-foreground text-sm">Isi data permohonan dan unggah berkas persyaratan.</p>
      </header>

      <%# Tampilkan error validasi jika ada %>
      <% if (errors && errors.length > 0) { %>
        <div class="mb-6 p-4 rounded-md border border-destructive bg-destructive/10 text-destructive text-sm">
          <p class="font-semibold mb-2">Permohonan gagal diproses:</p>
          <ul class="list-disc list-inside space-y-1">
            <% errors.forEach(e => { %>
              <li><%= e %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <%# enctype WAJIB multipart/form-data untuk upload file %>
      <form action="/requests" method="POST" enctype="multipart/form-data" class="form grid gap-6">

        <%# --- Jenis Permohonan --- %>
        <div class="grid gap-2">
          <label for="request_type" class="font-medium text-sm">
            Jenis Permohonan <span class="text-destructive">*</span>
          </label>
          <select name="request_type" id="request_type" class="select w-full" required
            onchange="toggleDocLabel(this.value)">
            <option value="" disabled <%= !old.request_type ? 'selected' : '' %>>Pilih Jenis Surat...</option>
            <option value="aktif" <%= old.request_type === 'aktif' ? 'selected' : '' %>>
              Surat Keterangan Aktif Kuliah
            </option>
            <option value="lulus" <%= old.request_type === 'lulus' ? 'selected' : '' %>>
              Surat Keterangan Kelulusan
            </option>
          </select>
        </div>

        <%# --- Keperluan / Judul --- %>
        <div class="grid gap-2">
          <label for="title" class="font-medium text-sm">
            Keperluan / Judul Surat <span class="text-destructive">*</span>
          </label>
          <input
            type="text" name="title" id="title" class="input w-full"
            placeholder="Cth: Syarat Beasiswa Pemprov 2026"
            value="<%= old.title || '' %>"
            minlength="5" maxlength="255" required
          >
        </div>

        <%# --- Keterangan Tambahan --- %>
        <div class="grid gap-2">
          <label for="description" class="font-medium text-sm">Keterangan Tambahan</label>
          <textarea
            name="description" id="description" class="textarea w-full" rows="3"
            placeholder="Jelaskan secara singkat detail kebutuhan surat Anda..."
          ><%= old.description || '' %></textarea>
        </div>

        <%# --- Upload KRS (Wajib) --- %>
        <div class="grid gap-2">
          <label for="krs_file" class="font-medium text-sm">
            Unggah KRS (Kartu Rencana Studi) <span class="text-destructive">*</span>
          </label>
          <input
            type="file" name="krs_file" id="krs_file" class="input w-full"
            accept=".pdf,.jpg,.jpeg,.png" required
          >
          <p class="text-xs text-muted-foreground">Format: PDF, JPG, atau PNG. Maks 5MB.</p>
        </div>

        <%# --- Upload Dokumen Tambahan (Opsional) --- %>
        <div class="grid gap-2">
          <label for="additional_file" class="font-medium text-sm" id="additional_file_label">
            Dokumen Tambahan <span class="text-muted-foreground">(opsional)</span>
          </label>
          <input
            type="file" name="additional_file" id="additional_file" class="input w-full"
            accept=".pdf,.jpg,.jpeg,.png"
          >
          <p class="text-xs text-muted-foreground" id="additional_file_hint">
            Unggah dokumen pendukung lainnya jika diperlukan.
          </p>
        </div>

        <footer class="flex justify-end mt-4 pt-4 border-t">
          <button type="submit" class="btn">Kirim Permohonan</button>
        </footer>
      </form>
    </div>
  </div>
</div>

<script>
  // Ubah label dokumen tambahan sesuai jenis permohonan
  function toggleDocLabel(type) {
    const label = document.getElementById('additional_file_label');
    const hint  = document.getElementById('additional_file_hint');
    if (type === 'lulus') {
      label.innerHTML = 'Bukti Pendaftaran Wisuda / Dokumen Kelulusan <span class="text-muted-foreground">(opsional)</span>';
      hint.textContent = 'Unggah bukti pendaftaran wisuda atau dokumen kelulusan lainnya.';
    } else {
      label.innerHTML = 'Dokumen Tambahan <span class="text-muted-foreground">(opsional)</span>';
      hint.textContent = 'Unggah dokumen pendukung lainnya jika diperlukan.';
    }
  }
  // Jalankan saat halaman load jika ada nilai lama (setelah error)
  const sel = document.getElementById('request_type');
  if (sel.value) toggleDocLabel(sel.value);
</script>

<%- include('../partials/_foot.ejs') %>
