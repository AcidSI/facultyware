<%- include('../partials/_head.ejs') %>

<div class="p-6 md:p-10 ml-2 relative ">
  <div class="max-w-3xl mx-auto space-y-6">

    <div class="flex flex-col items-start gap-4 mb-4">
      <div>
        <p class="text-sm text-muted-foreground">Pembaruan status permohonan,</p>
        <h1 class="text-2xl font-bold tracking-tight mt-1 text-foreground">Notifikasi Saya</h1>
      </div>
      <a href="/home" hx-boost="true" class="bg-background border border-border text-foreground hover:bg-muted h-9 px-3 py-1.5 rounded-lg inline-flex items-center gap-2 shadow-sm text-sm font-medium transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Kembali ke Beranda
      </a>
    </div>

    <div class="grid gap-6">
      <% if (notifs && notifs.length > 0) { %>
        <% notifs.forEach(n => { %>
          
          <div class="card bg-card text-card-foreground p-5 md:p-6 rounded-xl border border-border shadow-sm flex flex-col gap-4 border-l-4 <%= n.status === 3 ? 'border-l-green-500' : 'border-l-red-500' %>">
            
            <div class="flex justify-between items-start">
  <span class="text-xs text-muted-foreground font-medium mt-1">
    <%= new Date(n.updated_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
  </span>
  
  <% 
    let labelStatus = n.badge.label.toLowerCase(); 
    let forceStyle = "";
    
    if (labelStatus.includes('selesai') || labelStatus.includes('batal')) {
      // Selesai: Latar gelap (hitam/adaptif tema), teks terang
      forceStyle = "background-color: hsl(var(--primary)) !important; color: hsl(var(--primary-foreground)) !important; border-color: hsl(var(--primary)) !important;";
    } else if (labelStatus.includes('tolak')) {
      // Tolak: Merah pekat, teks putih
      forceStyle = "background-color: #ef4444 !important; color: #ffffff !important; border-color: #b91c1c !important;";
    } else {
      // Menunggu/Proses: Kuning, teks hitam
      forceStyle = "background-color: #facc15 !important; color: #000000 !important; border-color: #ca8a04 !important;";
    }
  %>
  
  <span class="<%= n.badge.class %> text-[10px] px-2.5 py-1.3 rounded-full uppercase font-bold tracking-wider shadow-sm border border-border" style="<%= forceStyle %>">
    <%= n.badge.label %>
  </span>
</div>

            <div class="grid gap-1">
              <p class="font-bold text-base text-foreground tracking-tight"><%= n.title %></p>
              <p class="text-sm text-muted-foreground font-mono">No. Surat: <%= n.request_nunmber || '-' %></p>
            </div>

            <div class="mt-1">
              <a href="/requests/<%= n.id %>" class="bg-background border border-border text-foreground hover:bg-muted text-xs h-4 px-3 py-3 rounded-lg shadow-sm font-semibold transition-colors inline-flex items-center justify-center" hx-boost="true">
                Lihat Detail
              </a>
            </div>

          </div>

        <% }) %>
      <% } else { %>
        
        <div class="card bg-card text-card-foreground rounded-xl border border-border shadow-sm p-12 text-center flex flex-col items-center justify-center border-dashed">
          <div class="size-12 rounded-full bg-muted flex items-center justify-center text-muted-foreground mb-4 border border-border shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
          </div>
          <p class="font-bold text-foreground text-sm mb-1 tracking-tight">Belum ada notifikasi</p>
          <p class="text-muted-foreground text-xs">Saat ini belum ada pembaruan status dari permohonan surat Anda.</p>
        </div>

      <% } %>
    </div>

  </div>
</div>

<%- include('../partials/_foot.ejs') %>