<%- include('../partials/_head.ejs') %>

<div class="p-4 md:p-6 xl:p-12">
  <div class="max-w-3xl mx-auto">
    <div class="mb-6 flex items-center gap-2">
      <a href="/requests" class="btn-sm-ghost" hx-boost="true">← Kembali</a>
    </div>

    <div class="card relative p-6 md:p-8">
      <div class="absolute top-0 right-0 p-6">
        <span class="<%= request.badge.class %> text-sm px-3 py-1"><%= request.badge.label %></span>
      </div>

      <header class="pb-6 border-b">
        <h2 class="text-2xl font-bold mb-1"><%= request.title %></h2>
        <p class="text-muted-foreground text-sm flex gap-3 flex-wrap">
          <span class="font-mono bg-muted px-2 py-0.5 rounded"><%= request.request_nunmber %></span>
          <span class="uppercase font-semibold">
            <%= request.request_type === 'aktif' ? 'Surat Keterangan Aktif Kuliah' : 'Surat Keterangan Kelulusan' %>
          </span>
        </p>
      </header>

      <section class="grid grid-cols-1 md:grid-cols-2 gap-y-6 gap-x-12 pt-6">
        <div class="grid gap-1">
          <span class="text-sm text-muted-foreground">Nama Mahasiswa</span>
          <p class="font-medium"><%= request.student_name %></p>
        </div>
        <div class="grid gap-1">
          <span class="text-sm text-muted-foreground">NIM / Nomor Induk</span>
          <p class="font-medium font-mono"><%= request.nim %></p>
        </div>
        <div class="grid gap-1">
          <span class="text-sm text-muted-foreground">Tanggal Pengajuan</span>
          <p class="font-medium">
            <%= new Date(request.requested_at).toLocaleString('id-ID', { dateStyle: 'long', timeStyle: 'short' }) %> WIB
          </p>
        </div>
        <div class="grid gap-1">
          <span class="text-sm text-muted-foreground">Terakhir Diperbarui</span>
          <p class="font-medium">
            <%= request.updated_at ? new Date(request.updated_at).toLocaleString('id-ID') : '-' %>
          </p>
        </div>

        <div class="grid gap-2 md:col-span-2 mt-2">
          <span class="text-sm font-medium">Keterangan Surat</span>
          <div class="p-4 bg-muted rounded-md text-sm leading-relaxed border border-border">
            <%= request.description || 'Tidak ada keterangan tambahan.' %>
          </div>
        </div>
      </section>

      <%# --- Berkas yang Diunggah --- %>
      <% if (documents) { %>
        <section class="mt-6 pt-6 border-t">
          <h3 class="font-semibold text-sm mb-4">Berkas Persyaratan</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <% if (request.request_type === 'aktif') { %>
              <% if (documents.student_study_plan_file) { %>
                <a href="/uploads/requests/<%= documents.student_study_plan_file %>"
                   target="_blank" class="btn-sm-outline flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  Lihat KRS
                </a>
              <% } %>
              <% if (documents.parent_decree_file) { %>
                <a href="/uploads/requests/<%= documents.parent_decree_file %>"
                   target="_blank" class="btn-sm-outline flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  Lihat Dokumen Tambahan
                </a>
              <% } %>
            <% } else if (request.request_type === 'lulus') { %>
              <% if (documents.cover_letter_department_file) { %>
                <a href="/uploads/requests/<%= documents.cover_letter_department_file %>"
                   target="_blank" class="btn-sm-outline flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  Lihat KRS / Dokumen Utama
                </a>
              <% } %>
              <% if (documents.proof_o_grad_registration_file) { %>
                <a href="/uploads/requests/<%= documents.proof_o_grad_registration_file %>"
                   target="_blank" class="btn-sm-outline flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  Lihat Bukti Pendaftaran Wisuda
                </a>
              <% } %>
            <% } %>

            <%# Catatan dari admin (jika ada) %>
            <% if (documents.check_reason) { %>
              <div class="md:col-span-2">
                <span class="text-sm text-muted-foreground">Catatan Verifikasi Admin</span>
                <p class="mt-1 p-3 bg-muted rounded text-sm"><%= documents.check_reason %></p>
              </div>
            <% } %>
            <% if (documents.sign_reason) { %>
              <div class="md:col-span-2">
                <span class="text-sm text-muted-foreground">Catatan Penandatanganan</span>
                <p class="mt-1 p-3 bg-muted rounded text-sm"><%= documents.sign_reason %></p>
              </div>
            <% } %>
          </div>
        </section>
      <% } %>

      <footer class="mt-8 pt-6 border-t flex justify-end gap-3">
        <%# Tombol batal hanya muncul jika status masih "Menunggu" (0) %>
        <% if (request.status === STATUS.MENUNGGU) { %>
          <button
            type="button"
            class="btn-destructive"
            hx-post="/requests/<%= request.id %>/cancel"
            hx-confirm="Apakah Anda yakin ingin membatalkan permohonan ini? Tindakan ini tidak dapat diubah."
          >
            Batalkan Permohonan
          </button>
        <% } %>
      </footer>
    </div>
  </div>
</div>

<%- include('../partials/_foot.ejs') %>
