<%- include('./partials/_head.ejs') %>

<div class="p-6 md:p-10 ml-2">
  <div class="mx-auto space-y-6" style="max-width: 770px;">

    <%# ── Greeting ── %>
    <div class="mb-2">
      <p class="text-sm text-muted-foreground">Selamat datang kembali,</p>
      <h1 class="text-2xl font-bold tracking-tight mt-0.5"><%= student.name || user %></h1>
    </div>

    <%# ── Stats ── %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="card flex flex-col justify-between p-6 gap-6">
        <p class="text-xs text-muted-foreground font-medium uppercase tracking-wide">Total</p>
        <p class="text-5xl font-bold tabular-nums leading-none"><%= stats.total %></p>
      </div>
      <div class="card flex flex-col justify-between p-6 gap-6">
        <p class="text-xs text-muted-foreground font-medium uppercase tracking-wide">Menunggu</p>
        <p class="text-5xl font-bold tabular-nums leading-none text-yellow-500"><%= stats.menunggu %></p>
      </div>
      <div class="card flex flex-col justify-between p-6 gap-6">
        <p class="text-xs text-muted-foreground font-medium uppercase tracking-wide">Diproses</p>
        <p class="text-5xl font-bold tabular-nums leading-none text-blue-500"><%= stats.diproses %></p>
      </div>
      <div class="card flex flex-col justify-between p-6 gap-6">
        <p class="text-xs text-muted-foreground font-medium uppercase tracking-wide">Selesai</p>
        <p class="text-5xl font-bold tabular-nums leading-none text-green-500"><%= stats.selesai %></p>
      </div>
    </div>

    <%# ── Quick Actions ── %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="card p-6 flex gap-4 items-start">
        <div class="size-9 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0 mt-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        </div>
        <div>
          <p class="font-semibold text-sm mb-1">Buat Permohonan Baru</p>
          <p class="text-xs text-muted-foreground mb-4 leading-relaxed">Ajukan Surat Keterangan Aktif Kuliah atau Surat Keterangan Lulus.</p>
          <a href="/requests/create" hx-boost="true" class="btn text-xs h-8 px-3">Mulai Pengajuan</a>
        </div>
      </div>
      <div class="card p-6 flex gap-4 items-start">
        <div class="size-9 rounded-lg bg-muted text-muted-foreground flex items-center justify-center shrink-0 mt-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div>
          <p class="font-semibold text-sm mb-1">Cek Status Permohonan</p>
          <p class="text-xs text-muted-foreground mb-4 leading-relaxed">Pantau progres verifikasi dan penandatanganan surat Anda.</p>
          <a href="/requests" hx-boost="true" class="btn-outline text-xs h-8 px-3">Lihat Riwayat</a>
        </div>
      </div>
    </div>

    <%# ── Permohonan Terbaru ── %>
    <% if (recentRequests && recentRequests.length > 0) { %>
    <div>
      <div class="flex justify-between items-center mb-3">
        <p class="font-semibold text-sm">Permohonan Terbaru</p>
        <a href="/requests" hx-boost="true" class="text-xs text-primary hover:underline">Lihat semua →</a>
      </div>
      <div class="card overflow-hidden">
        <table class="table w-full text-sm">
          <thead>
<tr class="bg-muted/60">
              <th class="text-xs font-semibold text-muted-foreground px-4 py-3 text-left uppercase tracking-wide">No Surat</th>
              <th class="text-xs font-semibold text-muted-foreground px-4 py-3 text-left uppercase tracking-wide">Keperluan</th>
              <th class="text-xs font-semibold text-muted-foreground px-4 py-3 text-left uppercase tracking-wide">Jenis</th>
              <th class="text-xs font-semibold text-muted-foreground px-4 py-3 text-left uppercase tracking-wide">Status</th>
              <th class="text-xs font-semibold text-muted-foreground px-4 py-3 text-left uppercase tracking-wide">Aksi</th>
            </tr>
            </tr>
          </thead>
          <tbody>
            <% recentRequests.forEach(r => { %>
<tr class="border-t hover:bg-muted/30 transition-colors">
              <td class="px-4 py-3 font-mono text-xs text-muted-foreground"><%= r.request_nunmber %></td>
              <td class="px-4 py-3 max-w-[180px] truncate"><%= r.title || '-' %></td>
              <td class="px-4 py-3 uppercase text-xs font-semibold text-muted-foreground"><%= r.request_type %></td>
             <td class="px-4 py-3">
  <% 
    let labelStatus = r.badge.label.toLowerCase();
    let themeClass = "";
    let forceStyle = "";
    
    if (labelStatus.includes('selesai') || labelStatus.includes('batal')) {
      // Selesai: Sepenuhnya mengikuti tema bawaan (background dan teks adaptif)
      themeClass = "bg-primary text-primary-foreground border border-primary";
    } else if (labelStatus.includes('tolak')) {
      // Ditolak: Kunci mutlak Background Merah dan Teks Putih
      themeClass = "border border-[#b91c1c]";
      forceStyle = "background-color: #ef4444 !important; color: #ffffff !important;";
    } else {
      // Menunggu: Kunci mutlak Background Kuning dan Teks Hitam
      themeClass = "border border-[#ca8a04]";
      forceStyle = "background-color: #facc15 !important; color: #000000 !important;";
    }
  %>
  <span class="<%= themeClass %> px-2.5 py-1 rounded-full text-xs font-semibold whitespace-nowrap" style="<%= forceStyle %>">
    <%= r.badge.label %>
  </span>
</td>
              <td class="px-4 py-3">
                <% if (r.status === 3) { %>
                  <a href="/requests/<%= r.id %>/download" target="_blank" class="text-xs text-green-600 hover:underline font-semibold">
                    Unduh PDF
                  </a>
                <% } %>
              </td>
            </tr>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

  </div>
</div>

<%- include('./partials/_foot.ejs') %>
